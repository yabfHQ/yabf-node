{
    "compilerOptions": {
        // File Layout
        "rootDir": "./src",
        "outDir": "./dist",

        // Environment Settings
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "es2024",
        "lib": ["es2022"],
        "types": ["node"],

        // Other Outputs
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,

        // Recommended Options
        "strict": true,
        "skipLibCheck": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "isolatedModules": true,

        // Path Aliases
        "paths": {}
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
}
